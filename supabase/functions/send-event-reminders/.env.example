# Secrets for the send-event-reminders Edge Function.
# Set these on the deployed project with the Supabase CLI (NOT in this repo's root
# .env — that file only holds the browser-side VITE_SUPABASE_* values):
#
#   supabase secrets set --env-file supabase/functions/send-event-reminders/.env
#
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are provided automatically by the Supabase
# Edge Function runtime — do not set them here.

# Resend (https://resend.com) API key used to send reminder emails.
RESEND_API_KEY=your-resend-api-key

# "From" address reminder emails are sent as (must be a verified sender/domain in Resend).
EVENT_REMINDER_FROM_EMAIL=Gia Phả Dòng Họ Bùi <notify@yourdomain.example>
